# Salin file ini ke .env lalu isi nilainya
#   cp .env.example .env
# Di Vercel: Project Settings → Environment Variables (isi nilai yang sama)

# URL Google Apps Script Web App (didapat setelah deploy GAS sebagai Web App "Anyone")
GAS_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXX/exec

# (Opsional) Password area admin
ADMIN_PASSWORD=

# (Opsional) URL Google Form "Lapor Bug"
BUG_URL=

# (Opsional) URL Google Form "Nilai Aplikasi / Survei"
RATING_URL=

# (Opsional) Kata sandi untuk tombol "Override (Admin)" pada overlay survei tahunan
RATING_OVERRIDE_PASSWORD=

# Catatan: on/off overlay survei diatur dari tab "Pengaturan" (kunci SURVEY_AKTIF), bukan di sini.
